# ═══════════════════════════════════════════════
# RedNode-OS v0.8.0 – Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env
# ═══════════════════════════════════════════════

# ─── Core Infrastructure ───
DATABASE_URL=postgres://rednode:rednode@localhost:5432/rednode
NATS_URL=nats://localhost:4222
QDRANT_URL=http://localhost:6334
OLLAMA_URL=http://localhost:11434
REDNODE_CNS=http://localhost:8787
RUST_LOG=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ─── LLM Model ───
# Choose based on your GPU VRAM:
#   6 GB:  qwen2.5:7b-instruct-q4_K_M
#   12 GB: qwen2.5:14b-instruct-q4_K_M  (recommended)
#   24 GB: qwen2.5:32b-instruct-q4_K_M
REDNODE_MODEL=qwen2.5:14b-instruct-q4_K_M
# Separate model for code generation (optional — defaults to REDNODE_MODEL)
REDNODE_CODE_MODEL=

# ─── Sentience Engine ───
REDNODE_SENTIENCE=on
REDNODE_NODE_ID=rednode-primary
REDNODE_HOSTNAME=rednode

# ─── API Authentication ───
# Set a token to enable auth. Leave empty to disable (dev mode).
# Generate: python3 -c "import secrets; print(f'rn_{secrets.token_hex(32)}')"
REDNODE_API_TOKEN=

# ─── Pi-hole (Infrastructure Agent) ───
PIHOLE_URL=http://10.0.50.2
PIHOLE_PASSWORD=your-pihole-admin-password

# ─── TrueNAS (Storage Agent) ───
# Create API key: TrueNAS UI → Settings → API Keys → Add
TRUENAS_URL=https://10.0.50.3
TRUENAS_API_KEY=your-truenas-api-key

# ─── Frigate NVR (Surveillance Agent) ───
FRIGATE_URL=http://localhost:5000
MQTT_URL=mqtt://127.0.0.1:1883
MQTT_USER=rednode
MQTT_PASS=rednode-mqtt

# ─── Email (Communications Agent) ───
# IMAP (receiving)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-email@gmail.com
IMAP_PASS=your-app-password
# SMTP (sending)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ─── Calendar (Communications Agent) ───
# CalDAV (Nextcloud, Google via DAV, Radicale, etc.)
CALDAV_URL=https://your-nextcloud.com/remote.php/dav
CALDAV_USER=your-username
CALDAV_PASS=your-password

# ─── Voice Interface ───
REDNODE_VOICE=off
STT_PORT=8081
TTS_PORT=8082
STT_URL=http://localhost:8081
TTS_URL=http://localhost:8082
CNS_URL=http://localhost:8787
# Whisper STT
WHISPER_MODEL=large-v3
WHISPER_DEVICE=auto
WHISPER_COMPUTE=float16
WHISPER_LANGUAGE=
WHISPER_BEAM_SIZE=5
WHISPER_MODEL_DIR=/var/lib/rednode/whisper-models
# Piper TTS
PIPER_VOICE=en_US-lessac-medium
PIPER_DATA_DIR=/var/lib/rednode/piper-voices
PIPER_RATE=1.0
PIPER_SPEAKER=0
# Wake word
# Built-in: hey_jarvis, alexa, hey_mycroft, ok_google
# Custom: python interfaces/voice/voice_loop.py --train-wake-word "hey rednode"
# Multiple: WAKE_WORD=hey_jarvis,alexa
WAKE_WORD=hey_jarvis
WAKE_WORD_MODEL_DIR=/var/lib/rednode/wake-word-models
WAKE_THRESHOLD=0.7
TRAIN_SAMPLES=20

# ─── Security Agent ───
REDNODE_SECURITY_MODE=on
REDNODE_PATCH_DRY_RUN=true
CVE_DB_PATH=/var/lib/rednode/cve-db.json
CVE_SYNC_STATE=/var/lib/rednode/nvd-sync-state.json
FALCO_LOG=/var/log/falco/falco.log

# ─── Threat Intelligence ───
# AlienVault OTX (free): https://otx.alienvault.com/api
OTX_API_KEY=
# NVD API (free, faster with key): https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=
NVD_SYNC_INTERVAL=86400000
# VirusTotal (free tier: 4 req/min): https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=
# pfSense API for auto-blocking IOCs
PFSENSE_URL=https://10.0.50.1
PFSENSE_API_KEY=
PFSENSE_API_SECRET=
# Auto-block IOCs on pfSense firewall (set "true" to enable)
THREAT_INTEL_AUTO_BLOCK=false
THREAT_INTEL_INTERVAL=3600000
THREAT_INTEL_DIR=/var/lib/rednode/threat-intel
# Dark web OSINT (requires Tor: apt install tor)
TOR_SOCKS_PROXY=socks5h://127.0.0.1:9050

# ─── Browser Agent ───
DOWNLOAD_DIR=/var/lib/rednode/downloads
MAX_DOWNLOAD_MB=500
BROWSER_ALLOW_INTERNAL=false

# ─── Productivity Agent ───
NOTES_DIR=/var/lib/rednode/notes
TASKS_FILE=/var/lib/rednode/tasks.json
BOOKMARKS_FILE=/var/lib/rednode/bookmarks.json

# ─── Coding Agent ───
# Auto-run security review after code generation (default: on)
CODE_AUTO_VERIFY=true

# ─── Signal Bot ───
# Install signal-cli: https://github.com/AsamK/signal-cli
SIGNAL_CLI_PATH=/usr/bin/signal-cli
SIGNAL_BOT_NUMBER=+1234567890
SIGNAL_OWNER_NUMBER=+1234567890
SIGNAL_POLL_INTERVAL=3000

# ─── Endpoint Agent (remote machines) ───
# Set on each remote machine, not on RedNode server
REDNODE_URL=http://10.0.50.10:8787
ENDPOINT_INTERVAL=300000

# ─── Jellyfin (Media Agent) ───
JELLYFIN_URL=http://localhost:8096
JELLYFIN_API_KEY=your-jellyfin-api-key

# ─── Home Assistant ───
HOME_ASSISTANT_URL=http://localhost:8123
HOME_ASSISTANT_TOKEN=your-long-lived-access-token

# ─── Social Media Agent ───
# Twitter/X (developer account: https://developer.twitter.com)
TWITTER_BEARER_TOKEN=
# Mastodon (any instance)
MASTODON_INSTANCE=https://mastodon.social
MASTODON_ACCESS_TOKEN=
# Bluesky (AT Protocol)
BLUESKY_HANDLE=your.handle.bsky.social
BLUESKY_APP_PASSWORD=
# LinkedIn (OAuth: https://developer.linkedin.com)
LINKEDIN_ACCESS_TOKEN=
# Instagram (Graph API: https://developers.facebook.com)
INSTAGRAM_ACCESS_TOKEN=
# WhatsApp Business (Cloud API: https://developers.facebook.com)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ─── SearXNG (Research Agent) ───
SEARXNG_URL=http://localhost:8888

# ─── Weather & News ───
# Location for weather (city name or coordinates). Leave empty for IP-based detection.
WEATHER_LOCATION=
# Region for news (e.g., "India", "US", "UK"). Filters news results.
NEWS_REGION=

# ─── Calendar Awareness ───
# Minutes before event to send reminder (default: 30)
CALENDAR_REMINDER_MINUTES=30

# ─── Knowledge Graph ───
KUZU_PATH=/var/lib/rednode/kuzu

# ─── PID1 Init Mode (advanced — binary paths for init.rs) ───
# Only used when running as PID1 (boot.kernelParams = init=/path/to/rednode-init)
REDNODE_CORE=/usr/bin/rednode-core
POSTGRES_BIN=/usr/bin/postgres
NATS_BIN=/usr/bin/nats-server
OLLAMA_BIN=/usr/bin/ollama

# ═══════════════════════════════════════════════
# v0.8.0 — New Features
# ═══════════════════════════════════════════════

# ─── Home Assistant (Home Agent) ───
HOMEASSISTANT_URL=http://10.0.20.100:8123
HOMEASSISTANT_TOKEN=your-long-lived-access-token
# Create in HA: Profile → Long-Lived Access Tokens → Create
# Used for: lights, climate, scenes, automations, entity control

# ─── WireGuard VPN (Network Agent) ───
WIREGUARD_ENABLED=false
WIREGUARD_PORT=51820
WIREGUARD_INTERFACE=wg0
WIREGUARD_ADDRESS=10.100.0.1/24
WIREGUARD_DNS=10.0.50.2
# Peer configs auto-generated: rednode intent "create VPN peer for my phone"

# ─── UPS Monitoring (System Agent) ───
UPS_ENABLED=false
UPS_DRIVER=usbhid-ups
UPS_PORT=auto
UPS_NAME=rednode-ups
UPS_SHUTDOWN_PERCENT=20
# Uses NUT (Network UPS Tools) — configured in NixOS
# Auto-graceful-shutdown when battery < UPS_SHUTDOWN_PERCENT

# ─── RSS/News Aggregator (Research Agent) ───
RSS_ENABLED=true
RSS_FEEDS=https://hnrss.org/frontpage|https://feeds.arstechnica.com/arstechnica/index|https://www.schneier.com/feed/
RSS_CHECK_INTERVAL=3600
RSS_MAX_ITEMS_PER_FEED=10
RSS_SUMMARIZE=true
# Add feeds separated by | (pipe)
# Digest delivered in morning briefing

# ─── Podcast Transcription (Research Agent) ───
PODCAST_ENABLED=false
PODCAST_FEEDS=
PODCAST_DOWNLOAD_DIR=/var/lib/rednode/podcasts
PODCAST_TRANSCRIBE=true
PODCAST_SUMMARIZE=true
# Downloads → Whisper transcription → LLM summary → searchable

# ─── Smart Notifications ───
NOTIFY_QUIET_START=22
NOTIFY_QUIET_END=7
NOTIFY_TIMEZONE_OFFSET=5
NOTIFY_CHANNEL=signal
# During quiet hours: only Critical notifications delivered immediately
# High → queued until morning. Normal/Low → batched into digest.

# ─── Suricata IDS (Security Agent) ───
SURICATA_ENABLED=false
SURICATA_EVE_LOG=/var/log/suricata/eve.json
SURICATA_AUTO_BLOCK=true
# Reads Suricata EVE JSON log → correlates with threat intel → auto-blocks on pfSense

# ─── Presence Detection ───
PRESENCE_ENABLED=false
PRESENCE_OWNER_DEVICES=owner-phone,owner-laptop
PRESENCE_CHECK_INTERVAL=300
PRESENCE_HOME_SCENE=home
PRESENCE_AWAY_SCENE=away
# Combines: camera person detection + network device presence + phone ping

# ─── Photo Management (Media Agent) ───
PHOTO_ENABLED=false
PHOTO_WATCH_DIR=/var/lib/rednode/photos
PHOTO_LIBRARY_DIR=/var/lib/rednode/photo-library
PHOTO_AUTO_ORGANIZE=true
PHOTO_AUTO_TAG=true
# Auto: detect new photos → classify by date → tag with CLIP → index for search

# ─── Predictive Maintenance ───
PREDICT_ENABLED=true
PREDICT_CHECK_INTERVAL=86400
PREDICT_ALERT_DAYS=30
# Collects SMART data, CPU temps, RAM errors → predicts failures

# ─── Email Auto-Triage (Comms Agent) ───
EMAIL_TRIAGE_ENABLED=true
EMAIL_TRIAGE_CATEGORIES=urgent,action,fyi,newsletter,spam
EMAIL_AUTO_DRAFT=false
EMAIL_DIGEST_TIME=08:00
# LLM classifies incoming email → priority inbox → optional auto-draft replies

# ─── Autonomous Learning Agent ───
LEARN_ENABLED=true
LEARN_INTERVAL=3600000
LEARN_AUTO_INGEST=true
# Discovers tools, reads docs, extracts patterns, suggests workflows

# ─── Custom LLM Fine-tuning ───
FINETUNE_ENABLED=false
FINETUNE_BASE_MODEL=qwen2.5:7b-instruct-q4_K_M
FINETUNE_DATASET_DIR=/var/lib/rednode/finetune
FINETUNE_OUTPUT_DIR=/var/lib/rednode/models
# See docs/guides/FINETUNE-LLM.md for full guide
