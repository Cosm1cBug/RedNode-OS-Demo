# RedNode-OS – Hardened Linux Kernel 6.9 LTS
# Privacy-first, security-first, eBPF enabled
#
# Base: nixpkgs linux_6_9_hardened
# Key options – merge into NixOS kernelPatches

# Security
CONFIG_SECURITY=y
CONFIG_SECURITY_LANDLOCK=y
CONFIG_SECURITY_YAMA=y
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_LOCK_DOWN_KERNEL_FORCE_CONFIDENTIALITY=y
CONFIG_SECURITY_BPF=y
CONFIG_BPF_LSM=y
CONFIG_SECURITY_LOADPIN=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_MEMORY=y
CONFIG_SLAB_FREELIST_RANDOM=y
CONFIG_SLAB_FREELIST_HARDENED=y
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y
CONFIG_CPU_MITIGATIONS=y

# eBPF – Security Telemetry – Falco / Tracee
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_HAVE_EBPF_JIT=y
CONFIG_BPF_EVENTS=y
CONFIG_KPROBE_EVENTS=y
CONFIG_UPROBE_EVENTS=y

# Integrity – IMA/EVM – for signed RedNode binaries
CONFIG_IMA=y
CONFIG_IMA_MEASURE_PCR_IDX=10
CONFIG_IMA_APPRAISE=y
CONFIG_EVM=y

# Namespaces – for sandboxing
CONFIG_NAMESPACES=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_CGROUP_NS=y

# Seccomp / BPF
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# Disable – reduce attack surface
# CONFIG_MODULES=n  # for fully static – breaks GPU drivers – keep =y for Phase 1
# CONFIG_BPF_JIT_ALWAYS_ON=y
# CONFIG_DEVMEM=n
# CONFIG_IO_STRICT_DEVMEM=y

# Performance – for local LLM
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y
# CONFIG_PREEMPT_VOLUNTARY=y

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_BTRFS_FS=y
CONFIG_BTRFS_FS_POSIX_ACL=y
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_ZSTD=y
CONFIG_OVERLAY_FS=y
CONFIG_FUSE_FS=y

# Encryption
CONFIG_DM_CRYPT=y
CONFIG_CRYPTO_AES_NI_INTEL=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_SHA512=y

# TPM2
CONFIG_TCG_TPM=y
CONFIG_TCG_TIS=y
CONFIG_TCG_CRB=y

# Networking – privacy
# CONFIG_IP_SCTP=n
# Disable uncommon protocols – reduce attack surface

# End – RedNode-OS kernel – privacy-first, security-first
