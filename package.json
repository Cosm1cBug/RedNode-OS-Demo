{
  "name": "rednode-os",
  "version": "0.9.0",
  "private": true,
  "description": "RedNode-OS \u2013 The Personal Autonomous Operating System",
  "packageManager": "pnpm@9.1.0",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3"
  },
  "workspaces": [
    "agents/*",
    "interfaces/web",
    "interfaces/cli"
  ],
  "scripts": {
    "agents": "pnpm -r --filter \"@rednode/*-agent\" --parallel dev",
    "agents:core": "pnpm -r --filter '@rednode/system-agent' --filter '@rednode/security-agent' --filter '@rednode/coding-agent' --filter '@rednode/research-agent' --filter '@rednode/automation-agent' --filter '@rednode/network-agent' --parallel dev",
    "agents:infra": "pnpm -r --filter '@rednode/infra-agent' --filter '@rednode/storage-agent' --filter '@rednode/surveillance-agent' --parallel dev",
    "web": "pnpm --filter @rednode/web dev",
    "cli": "pnpm --filter @rednode/cli dev"
  }
}
